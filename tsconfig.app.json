{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    // Core strict settings (like C# strict mode)
    "strict": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "noImplicitThis": true,
    "alwaysStrict": true,

    // These are handled as WARNINGS by ESLint instead (C# style)
    "noImplicitAny": false, // ESLint warns instead
    "strictNullChecks": false, // ESLint warns instead
    "strictPropertyInitialization": false, // Can be initialized in methods

    // Extra safety for array and object lookups
    "noUncheckedIndexedAccess": true,

    // Code quality checks - ERROR only on most severe
    "noUnusedLocals": false, // ESLint warns instead
    "noUnusedParameters": false, // ESLint warns instead
    "noImplicitReturns": true, // Error (logic bug)
    "noFallthroughCasesInSwitch": true, // Error (logic bug)

    // Path mapping for cleaner imports
    "paths": {
      "@/*": ["./src/*"]
    },

    // `vue-tsc --build` produces a .tsbuildinfo file for incremental type-checking
    // Specified here to keep it out of the root directory
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
